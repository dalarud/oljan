# Copy to .env and fill in. All values are OPTIONAL except Telegram
# (needed for push notifications). The system runs without any of these,
# falling back to console notifications and keyless data sources.

# --- Notifications (recommended) ---
# Create a bot via @BotFather on Telegram -> get the token.
# Get your chat id by messaging the bot then visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional data sources ---
# NewsAPI (https://newsapi.org) free dev tier: 100 req/day
NEWSAPI_KEY=

# EIA (https://www.eia.gov/opendata/register.php) free key for
# official weekly petroleum inventory data.
EIA_API_KEY=

# Reddit (https://www.reddit.com/prefs/apps -> create "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=oljan-oil-monitor/1.0
