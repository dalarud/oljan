# Copy to .env and fill in. All values are OPTIONAL except Telegram
# (needed for push notifications). The system runs without any of these,
# falling back to console notifications and keyless data sources.

# --- Notifications ---
# ntfy (recommended, no account needed): just choose a long, unguessable
# topic in config.yaml and subscribe to it in the ntfy app. A token is only
# needed for access-protected topics / self-hosted servers with auth.
NTFY_TOKEN=

# Telegram (alternative): create a bot via @BotFather -> get the token.
# Get your chat id by messaging the bot then visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X / Twitter (OPTIONAL): the X collector uses keyless Nitter RSS by default.
# Set a bearer token only if you have official X API v2 access (preferred when present).
X_BEARER_TOKEN=

# --- Optional data sources ---
# NewsAPI (https://newsapi.org) free dev tier: 100 req/day
NEWSAPI_KEY=

# EIA (https://www.eia.gov/opendata/register.php) free key for
# official weekly petroleum inventory data.
EIA_API_KEY=

# Alpha Vantage (https://www.alphavantage.co) free key. Provides REAL Brent/WTI
# DAILY prices (no intraday for the oil benchmarks; ~25 calls/day on free tier).
ALPHAVANTAGE_API_KEY=

# Twelve Data (https://twelvedata.com) free key (800 calls/day, 8/min).
# Free tier: Brent/WTI futures are paywalled, but the oil ETFs BNO (Brent) and
# USO (WTI) are available intraday. With scale_to_benchmark the ETF is anchored
# to the benchmark's real daily close -> Brent-level intraday ESTIMATE.
TWELVEDATA_API_KEY=

# Reddit (https://www.reddit.com/prefs/apps -> create "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=oljan-oil-monitor/1.0

# Anthropic (OPTIONAL): enables the LLM read of top headlines (llm.enabled in
# config.yaml). Uses a small, cheap model (claude-haiku-4-5) for context-aware
# direction/action classification. Without it the keyword lexicon is used.
ANTHROPIC_API_KEY=
